<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="@dimen/space_sm"
    android:paddingStart="@dimen/space_md"
    android:paddingEnd="@dimen/space_md">

    <!-- Avatar -->
    <FrameLayout
        android:layout_width="@dimen/avatar_size"
        android:layout_height="@dimen/avatar_size">

        <TextView
            android:id="@+id/contactAvatar"
            android:layout_width="@dimen/avatar_size"
            android:layout_height="@dimen/avatar_size"
            android:background="@drawable/bg_avatar"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="14sp" />

        <View
            android:id="@+id/onlineDot"
            android:layout_width="@dimen/online_dot_size"
            android:layout_height="@dimen/online_dot_size"
            android:layout_gravity="bottom|end"
            android:background="@drawable/bg_badge" />

    </FrameLayout>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/space_sm">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/contactName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/contactTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_meta"
                android:layout_marginStart="@dimen/space_sm" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/contactPreview"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_meta"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/unreadBadge"
                android:layout_width="@dimen/badge_size"
                android:layout_height="@dimen/badge_size"
                android:background="@drawable/bg_badge"
                android:gravity="center"
                android:textColor="@color/badge_text"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
