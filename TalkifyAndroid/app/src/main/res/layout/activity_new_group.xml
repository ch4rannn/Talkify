<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:paddingStart="@dimen/space_md"
        android:paddingEnd="@dimen/space_lg">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Back"
            android:scaleType="centerInside" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_group"
            android:textColor="@color/accent"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/space_sm" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Group Name Input -->
    <EditText
        android:id="@+id/groupNameInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="@string/group_name_hint"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_body"
        android:background="@color/surface"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg"
        android:singleLine="true"
        android:importantForAutofill="no"
        android:inputType="text"
        android:layout_margin="@dimen/space_md" />

    <!-- Select Members Label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/select_members"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_meta"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:textStyle="bold"
        android:paddingStart="@dimen/space_lg"
        android:paddingTop="@dimen/space_sm"
        android:paddingBottom="@dimen/space_sm" />

    <!-- Contact Selection List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/membersRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/space_sm" />

    <!-- Create Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/surface"
        android:padding="@dimen/space_md">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/createGroupButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/create_group"
            android:textColor="@color/text_on_accent"
            android:backgroundTint="@color/accent"
            android:textAllCaps="false"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

</LinearLayout>
