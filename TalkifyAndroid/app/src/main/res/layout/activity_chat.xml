<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/bg">

    <!-- Chat Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:paddingStart="@dimen/space_md"
        android:paddingEnd="@dimen/space_lg">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Back"
            android:scaleType="centerInside" />

        <!-- Avatar -->
        <TextView
            android:id="@+id/chatAvatar"
            android:layout_width="@dimen/avatar_size_small"
            android:layout_height="@dimen/avatar_size_small"
            android:background="@drawable/bg_avatar"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginStart="@dimen/space_sm" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/space_sm">

            <TextView
                android:id="@+id/chatName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chatStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_meta" />

        </LinearLayout>
        
        <ImageButton
            android:id="@+id/audioCallButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_audio_call"
            android:contentDescription="Voice Call"
            android:scaleType="centerInside"
            android:layout_marginEnd="@dimen/space_sm" />

        <ImageButton
            android:id="@+id/videoCallButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_video_call"
            android:contentDescription="Video Call"
            android:scaleType="centerInside" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/messagesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/space_sm" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Input Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:padding="@dimen/space_sm">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_sm">

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:hint="@string/type_message_hint"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:maxLines="3"
                android:inputType="textMultiLine"
                android:importantForAutofill="no" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/sendButton"
            android:layout_width="@dimen/send_button_size"
            android:layout_height="@dimen/send_button_size"
            android:layout_marginStart="@dimen/space_sm"
            android:background="@drawable/bg_send_button"
            android:src="@drawable/ic_send"
            android:contentDescription="@string/send"
            android:scaleType="centerInside"
            android:padding="10dp" />

    </LinearLayout>

</LinearLayout>
