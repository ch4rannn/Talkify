<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="80dp"
    android:paddingEnd="@dimen/space_md"
    android:paddingTop="@dimen/space_xs"
    android:paddingBottom="@dimen/space_xs">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="@drawable/bg_bubble_sent"
        android:padding="@dimen/space_md"
        android:maxWidth="280dp">

        <TextView
            android:id="@+id/sentMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/bubble_sent_text"
            android:textSize="@dimen/text_body"
            android:lineSpacingMultiplier="1.4" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/space_xs">

            <TextView
                android:id="@+id/sentTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_on_accent"
                android:textSize="@dimen/text_meta"
                android:alpha="0.6" />

            <TextView
                android:id="@+id/sentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/text_on_accent"
                android:textSize="@dimen/text_meta"
                android:alpha="0.7" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
