<?xml version="1.0" encoding="utf-8"?>
<!--
  Talkify — Sent message bubble (right-aligned, green accent)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="80dp"
    android:paddingEnd="@dimen/space_lg"
    android:paddingTop="@dimen/space_xs"
    android:paddingBottom="@dimen/space_xs">

    <!-- Bubble card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/sentBubbleCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bubble_sent_bg"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <TextView
                android:id="@+id/sentMessageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/bubble_sent_text"
                android:textSize="@dimen/text_body"
                android:lineSpacingMultiplier="1.4" />

            <TextView
                android:id="@+id/sentTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/space_xs"
                android:textColor="@color/text_on_accent"
                android:textSize="@dimen/text_meta"
                android:alpha="0.6" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
