<?xml version="1.0" encoding="utf-8"?>
<!--
  Talkify — Received message bubble (left-aligned, dark surface)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/space_lg"
    android:paddingEnd="80dp"
    android:paddingTop="@dimen/space_xs"
    android:paddingBottom="@dimen/space_xs">

    <!-- Bubble card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/receivedBubbleCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bubble_received_bg"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="0dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <TextView
                android:id="@+id/receivedMessageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/bubble_received_text"
                android:textSize="@dimen/text_body"
                android:lineSpacingMultiplier="1.4" />

            <TextView
                android:id="@+id/receivedTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/space_xs"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_meta"
                android:alpha="0.6" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
